<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Cross-Browser Suite
  Run: mvn test -Pcross-browser
  Executes the full test set on Chrome, Firefox and Edge sequentially.
-->
<suite name="MultiBank Cross-Browser" verbose="1" parallel="tests" thread-count="3">

    <listeners>
        <listener class-name="com.multibank.listeners.TestListener"/>
        <listener class-name="com.multibank.listeners.RetryTransformer"/>
    </listeners>

    <!-- ── Chrome ───────────────────────────────────────────────── -->
    <test name="Chrome – Navigation">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Chrome – Trading">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.multibank.tests.TradingTest"/>
        </classes>
    </test>

    <test name="Chrome – Content">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.multibank.tests.ContentTest"/>
        </classes>
    </test>

    <!-- ── Firefox ──────────────────────────────────────────────── -->
    <test name="Firefox – Navigation">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Firefox – Trading">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.multibank.tests.TradingTest"/>
        </classes>
    </test>

    <test name="Firefox – Content">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.multibank.tests.ContentTest"/>
        </classes>
    </test>

    <!-- ── Edge ─────────────────────────────────────────────────── -->
    <test name="Edge – Navigation">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Edge – Trading">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.multibank.tests.TradingTest"/>
        </classes>
    </test>

    <test name="Edge – Content">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.multibank.tests.LoginTest"/>
        </classes>
    </test>

</suite>
