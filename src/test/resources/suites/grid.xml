<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Selenium Grid / Cloud Suite
  Run: mvn test -Pgrid -Dgrid.url=http://<hub>:4444/wd/hub

  For Sauce Labs:  -Dgrid.url=https://<user>:<key>@ondemand.saucelabs.com/wd/hub
  For BrowserStack: -Dgrid.url=https://<user>:<key>@hub.browserstack.com/wd/hub
-->
<suite name="MultiBank Grid Execution" verbose="1" parallel="tests" thread-count="4">

    <listeners>
        <listener class-name="com.multibank.listeners.TestListener"/>
        <listener class-name="com.multibank.listeners.RetryTransformer"/>
    </listeners>

    <test name="Grid – Chrome – Navigation">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Grid – Chrome – Trading">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.multibank.tests.TradingTest"/>
        </classes>
    </test>

    <test name="Grid – Firefox – Navigation">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Grid – Firefox – Content">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.multibank.tests.ContentTest"/>
        </classes>
    </test>

</suite>
