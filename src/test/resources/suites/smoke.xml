<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Smoke Suite – fast sanity check (< 3 min target)
  Run: mvn test -Psmoke
-->
<suite name="MultiBank Smoke" verbose="1" parallel="classes" thread-count="2">

    <listeners>
        <listener class-name="com.multibank.listeners.TestListener"/>
        <listener class-name="com.multibank.listeners.RetryTransformer"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
            <class name="com.multibank.tests.TradingTest"/>
            <class name="com.multibank.tests.ContentTest"/>
        </classes>
    </test>

</suite>
